# Copy to .env and fill before: uvicorn api.main_api:app --reload --port 8000
# (python-dotenv is optional; or export variables in PowerShell)

# Colab tracking-only server (URL from colab_tracking.ipynb — no /api suffix)
# COLAB_TRACKING_URL=https://xxxx.ngrok-free.app

# Optional: custom stub path after Colab download
# TRACK_STUB_PATH=stubs/track_stubs.pkl

# Force local YOLO tracking instead of Colab stub
# FORCE_TRACKING=1

# Optional: LLM tactical report (TacticalNarrator → llm_analysis.json)
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1
# Gemini: LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  LLM_MODEL=gemini-2.5-flash
# LLM_MAX_TOKENS=8192
# LLM_TIMEOUT=180
